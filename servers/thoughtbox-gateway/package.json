{
  "name": "@kastalien-research/thoughtbox-gateway",
  "version": "0.1.0",
  "description": "Code-mode MCP gateway for Dedalus Marketplace tools",
  "private": false,
  "type": "module",
  "bin": {
    "thoughtbox-gateway": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && node -e \"require('fs').chmodSync('dist/index.js', '755')\"",
    "start": "node dist/index.js --port 8080",
    "dev:stdio": "tsx src/index.ts",
    "dev:shttp": "tsx src/index.ts --port 8080",
    "prepare": "bun run build",
    "test": "vitest run",
    "watch": "tsc --watch"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.25.3",
    "express": "5.1.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/node": "22.19.15",
    "tsx": "4.20.3",
    "typescript": "5.9.2",
    "vitest": "4.1.2"
  }
}

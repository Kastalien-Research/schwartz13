{
  "name": "google-workspace",
  "description": "Google Workspace channel for Claude Code — receive inbound Gmail notifications and reply, draft, triage, and summarize threads in real time.",
  "version": "0.1.0",
  "mcpServers": {
    "google-workspace-channel": {
      "command": "npm",
      "args": ["--prefix", "${CLAUDE_PLUGIN_ROOT}", "run", "channel"]
    }
  },
  "channels": {
    "google-workspace-channel": {
      "server": "google-workspace-channel"
    }
  },
  "userConfig": {
    "GOOGLE_CLIENT_ID": {
      "description": "Google OAuth 2.0 Client ID",
      "required": true,
      "sensitive": true
    },
    "GOOGLE_CLIENT_SECRET": {
      "description": "Google OAuth 2.0 Client Secret",
      "required": true,
      "sensitive": true
    },
    "GOOGLE_REFRESH_TOKEN": {
      "description": "Google OAuth 2.0 Refresh Token (run 'npm run auth' to obtain)",
      "required": true,
      "sensitive": true
    }
  }
}
